# Central admin registry Apps Script web app
PHONEDUKAAN_REGISTRY_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_REGISTRY_DEPLOYMENT_ID/exec
APPS_SCRIPT_ADMIN_SECRET=your-admin-secret

# Optional default customer sync script
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/s/YOUR_CUSTOMER_DEPLOYMENT_ID/exec
APPS_SCRIPT_SYNC_KEY=

# Admin panel login for /777admin
PHONEDUKAAN_ADMIN_ID=change-me-admin-id
PHONEDUKAAN_ADMIN_PASSWORD=change-me-strong-password
